{
  "openapi": "3.0.1",
  "info": {
    "title": "YiQi ERP - Seguridad",
    "version": "0"
  },
  "servers": [
    {
      "url": "https://api.yiqi.com.ar/"
    }
  ],
  "paths": {
    "/token": {
      "summary": "Get a valid bearer token",
      "post": {
        "summary": "",
        "description": "",
        "operationId": "",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password",
                  "grant_type"
                ],
                "properties": {
                  "username": {
                    "type": "string",
                    "description": "A valid e-mail"
                  },
                  "password": {
                    "type": "string",
                    "description": "user password"
                  },
                  "grant_type": {
                    "type": "string",
                    "description": "password",
                    "example": "password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A valid token",
            "content": {
              "application/json": {
                "examples": {
                  "A sample token (this is just an example, don´t try to use it)": {
                    "value": "{\n  \"access_token\": \"sdfsdfsdfsdfsdfPFhfVAv0mTa-B9wN9nhK6QuB8jECFM4j4HxL26s4vfIahTIJa5c1rJ7qhtLtaDfwtnYViuixZzvQcJq8tmw2OkDQSFsXXtzAcZEHbXiBH2svEXfj-o9ih4j4pS8ibeDdH8g_RhI363BUw6yCepmhYqRxkTubDOf885E5p-oSn9sjhxGroTPOHL3QxeUHZiW7QkgP1YN4_jQresdfsdfsdfsdf9Y-ZUWCBVfTkki6dfLOZHUBa70Ikmj4wrEG2-hG5dEdreGVs53O2BzaoU_r2F-fu0T8nfN36LTFUK_KtKGjB3ZkNOssljZE25mrKJw5jHkykrTyNgsmNySilAEw5uOaho8wL6nXX41ktgiFrvgRpFwYw_TNYy7_M6-4z3Jr0TItqZsSgpfsA-UrQF3J8fc24x-n3enSwTH3qi20rn0B4RS0RLmTsah3ich-2rWeTDbMvKCpuA\",\n  \"token_type\": \"bearer\",\n  \"expires_in\": 120959999,\n  \"userName\": \"xxx@test.com\",\n  \".issued\": \"Mon, 30 May 2022 23:29:34 GMT\",\n  \".expires\": \"Mon, 30 Mar 2026 23:29:34 GMT\"\n}"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid username or password"
          }
        }
      }
    },
    "/accountapi/GetLoginInformation": {
      "summary": "Get current login information",
      "get": {
        "summary": "Get login information.",
        "description": "Returns current user login information for the provided schema.",
        "operationId": "GetLoginInformation",
        "parameters": [
          {
            "name": "schemaId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            },
            "description": "Schema identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Login information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "userId": {
                      "type": "integer",
                      "format": "int64"
                    },
                    "userName": {
                      "type": "string"
                    },
                    "schemaName": {
                      "type": "string"
                    },
                    "host": {
                      "type": "string"
                    },
                    "schemaId": {
                      "type": "integer",
                      "format": "int32"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid token"
          }
        }
      }
    },
    "/schemasapi/GetAvailable": {
      "summary": "Get available schemas for current user",
      "get": {
        "summary": "Get available schemas.",
        "description": "Returns schemas the logged-in user can access.",
        "operationId": "GetAvailableSchemas",
        "responses": {
          "200": {
            "description": "Available schemas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "format": "int32"
                      },
                      "name": {
                        "type": "string"
                      },
                      "imgName": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid token"
          }
        }
      }
    }
  }
}