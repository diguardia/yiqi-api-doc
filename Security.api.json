  "paths": {
    "/token": {
      "summary": "Get a valid bearer token",
      "post": {
        "summary": "",
        "description": "",
        "operationId": "",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password",
                  "grant_type"
                ],
                "properties": {
                  "username": {
                    "type": "string",
                    "description": "A valid e-mail"
                  },
                  "password": {
                    "type": "string",
                    "description": "user password"
                  },
                  "grant_type": {
                    "type": "string",
                    "description": "password",
                    "example": "password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A valid token",
            "content": {
